---
import Section from './Section.astro';
---
<Section id="aktuell" eyebrow="Aktuell" heading="Abschlusskonzert — Orgelkonzert">
  <div class="grid gap-10 md:grid-cols-[1fr_1.3fr] md:items-center">
    <img
      src="/images/abschlusskonzert-plakat.svg"
      alt="Konzertplakat Abschlusskonzert, Pauluskirche Zehlendorf"
      width="594"
      height="841"
      loading="lazy"
      class="w-full max-w-sm rounded-lg border border-[var(--color-line)]"
    />
    <div class="space-y-5 text-lg leading-relaxed text-stone">
      <p>
        Sonntag, 16. August 2026, 19 Uhr &mdash; Pauluskirche Zehlendorf, Berlin.
        Abschlusskonzert im Rahmen der Kirchenmusikausbildung, Orgel: Niklas Lustig.
      </p>
      <a href="#kontakt" class="inline-block text-sm text-brass underline underline-offset-4">
        Anfrage senden
      </a>
    </div>
  </div>
</Section>
