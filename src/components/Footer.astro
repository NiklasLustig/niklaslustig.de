  <div class="mx-auto flex max-w-5xl flex-col gap-4 px-6 text-sm text-stone sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {year} {NAME}</p>
    <nav class="flex gap-6">
      <a href="/impressum" class="hover:text-parchment">Impressum</a>
      <a href="/datenschutz" class="hover:text-parchment">Datenschutz</a>
    </nav>
  </div>
</footer>
