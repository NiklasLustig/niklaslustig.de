---
import Pipes from './Pipes.astro';
const NAME = 'Niklas Lustig';
---
<section id="top" class="relative">
  <div class="relative aspect-[16/9] w-full overflow-hidden">
    <img
      src="/images/conductor_portrait.svg"
      alt=""
      class="h-full w-full object-cover"
      style="transform: scale(1.18) translateY(-8%);"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)] via-[var(--color-ink)]/20 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 mx-auto max-w-5xl px-6 pb-12 sm:pb-16">
      <h1 class="font-display text-3xl leading-[1.05] text-parchment sm:text-5xl md:text-6xl">
        Klang. Raum. Gemeinschaft.
      </h1>
      <p class="mt-3 font-display text-xl text-parchment/90 sm:text-2xl">
        Orgel und Chor als eine Stimme.
      </p>
      <p class="mt-6 text-sm uppercase tracking-[0.28em] text-brass">{NAME}</p>
      <a href="#kontakt" class="mt-8 inline-block rounded-full bg-brass px-6 py-3 text-sm font-medium text-ink transition-transform hover:-translate-y-0.5">
        Anfrage senden
      </a>
    </div>
  </div>

  <div class="mx-auto max-w-5xl px-6 pt-10 pb-16 sm:pt-14 sm:pb-20">
    <p class="max-w-xl text-lg leading-relaxed text-stone">
      Kirchenmusiker, Organist und Chorleiter in Berlin. Kirchenmusik-Student an der
      Universität der Künste Berlin bei Henry Fairs (Orgel) und Kai-Uwe Jirka (Chorleitung).
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-6">
      <a href="#termine" class="text-sm text-stone underline-offset-4 hover:text-parchment hover:underline">
        Termine
      </a>
      <a href="#hoerproben" class="text-sm text-stone underline-offset-4 hover:text-parchment hover:underline">
        Hören
      </a>
    </div>
    <Pipes count={19} height={80} class="mt-16 opacity-90" />
  </div>
</section>
