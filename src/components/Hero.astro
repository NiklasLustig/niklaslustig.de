---
import Pipes from './Pipes.astro';
const NAME = 'Niklas Lustig';
---
<section id="top" class="relative mx-auto max-w-5xl px-6 pt-24 pb-28 sm:pt-32">
  <div class="grid gap-12 md:grid-cols-[1.3fr_1fr] md:items-center">
    <div>
      <h1 class="font-display text-4xl leading-[1.05] text-parchment sm:text-5xl md:text-6xl">
        Orgel und Chor als ein Klang &mdash; zwischen Liturgie, Konzertsaal und Gegenwart.
      </h1>
      <p class="mt-8 text-sm uppercase tracking-[0.28em] text-brass">{NAME}</p>
      <p class="mt-3 max-w-xl text-lg leading-relaxed text-stone">
        Kirchenmusiker, Organist und Chorleiter in Berlin. Kirchenmusik-Student an der
        Universität der Künste Berlin bei Henry Fairs (Orgel) und Kai-Uwe Jirka (Chorleitung).
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="#kontakt" class="rounded-full bg-brass px-6 py-3 text-sm font-medium text-ink transition-transform hover:-translate-y-0.5">
          Anfrage senden
        </a>
        <a href="#termine" class="text-sm text-stone underline-offset-4 hover:text-parchment hover:underline">
          Termine
        </a>
        <a href="#hoerproben" class="text-sm text-stone underline-offset-4 hover:text-parchment hover:underline">
          Hören
        </a>
      </div>
    </div>
    <img
      src="/images/niklas-organ.jpg"
      alt={`${NAME} an der Orgel`}
      class="aspect-[4/5] w-full rounded-lg border border-[var(--color-line)] object-cover object-right"
    />
  </div>
  <Pipes count={19} height={96} class="mt-20 opacity-90" />
</section>
