---
import Section from './Section.astro';
// Privacy note: click-to-load only, nothing third-party loads until clicked.
const clips = [
  { title: 'Orgelspiel — Ausschnitt', place: 'Instagram Reel', href: 'https://www.instagram.com/reels/DSMj5u_Dnb5/' },
];
---
<Section id="hoerproben" eyebrow="Hörproben" heading="Aufnahmen">
  <div class="grid gap-4 sm:grid-cols-2">
    {clips.map((c) => (
      <a
        href={c.href}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 rounded-lg border border-[var(--color-line)] bg-ink-raised p-5 transition-colors hover:border-brass/50"
      >
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full border border-brass/40 text-brass transition-colors group-hover:bg-brass group-hover:text-ink">
          &#9654;
        </span>
        <span>
          <span class="block text-parchment">{c.title}</span>
          <span class="block text-sm text-stone">{c.place}</span>
        </span>
      </a>
    ))}
  </div>
  <p class="mt-6 text-sm text-stone/70">Weitere Aufnahmen folgen in Kürze.</p>
</Section>
