---
// Shared section shell: eyebrow label + heading + slotted content.
interface Props { id: string; eyebrow: string; heading: string; }
const { id, eyebrow, heading } = Astro.props;
---
<section id={id} class="border-t border-[var(--color-line)] py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <p class="mb-3 text-xs uppercase tracking-[0.28em] text-brass">{eyebrow}</p>
    <h2 class="mb-12 font-display text-3xl text-parchment sm:text-4xl">{heading}</h2>
    <slot />
  </div>
</section>
